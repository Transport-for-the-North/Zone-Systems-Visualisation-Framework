# Azure Static Web Apps ignore file
# Files and directories to exclude from deployment

# Dependencies - CRITICAL: node_modules should NEVER be deployed
node_modules/
package-lock.json
package.json

# Source files
src/
public/
*.config.js
*.config.ts
vite.config.js
playwright.config.ts
eslint.config.js
jsconfig.json
tsconfig.json

# Test files
**/*.test.*
**/*.spec.*
test-results/
e2e/
coverage/
.nyc_output/

# Build tools
.git/
.github/
.vscode/
.idea/
scripts/

# Development files
.env
.env.local
.env.*.local
*.local
.DS_Store
Thumbs.db

# Documentation
README.md
CHANGELOG.md
LICENSE
docs/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Only deploy dist folder contents
# Everything else should be excluded
