{
  "name": "simple-vite-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local-vis-core": "cross-env VITE_USE_LOCAL_VIS_CORE=1 concurrently -k -n VISCORE,APP \"npm --prefix ../vis-core/packages/vis-core run build:watch\" \"vite\"",
    "build": "vite build",
    "build:analyze": "vite build && npm run analyze:size",
    "analyze:size": "node scripts/analyze-build-size.js",
    "postinstall": "npm install --no-save --force @rollup/rollup-linux-x64-gnu 2>/dev/null || npm install --no-save --force @rollup/rollup-linux-x64-musl 2>/dev/null || echo 'Rollup platform binary installation attempted'",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.7.0",
    "@mapbox/mapbox-gl-draw": "^1.5.0",
    "@mapcomponents/react-maplibre": "^1.6.1",
    "@ookla/mapbox-gl-draw-rectangle": "^1.2.2",
    "@transport-for-the-north/vis-core": "0.8.0",
    "@turf/turf": "^7.2.0",
    "chroma-js": "^3.1.2",
    "colorbrewer": "^1.6.1",
    "dompurify": "^3.3.3",
    "html-react-parser": "^5.2.7",
    "js-cookie": "^3.0.5",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "lodash.debounce": "^4.0.8",
    "lz-string": "^1.5.0",
    "mapbox-gl": "^3.15.0",
    "polished": "^4.3.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "^5.5.0",
    "react-leaflet": "^4.2.1",
    "react-modal": "^3.16.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.4",
    "react-select": "^5.10.2",
    "react-window": "^2.2.1",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "styled-components": "^6.1.19",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^2.1.8",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^25.0.1",
    "terser": "^5.44.1",
    "vite": "^7.1.2",
    "vitest": "^2.1.8"
  }
}